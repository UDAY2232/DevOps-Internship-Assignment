[Unit]
Description=DevOps Assignment - API Gateway (FastAPI)
After=network.target

[Service]
Type=simple
User=devops
Group=devops
EnvironmentFile=/etc/devops-assignment.env
WorkingDirectory=/opt/devops-assignment/app/api
ExecStart=/opt/devops-venv/bin/uvicorn main:app --host 0.0.0.0 --port 8080 --proxy-headers
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
